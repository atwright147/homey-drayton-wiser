{
  "name": {
    "en": "Wiser HeatHub"
  },
  "class": "other",
  "capabilities": [
    "wiser_away_mode",
    "wiser_comfort_mode",
    "wiser_eco_mode",
    "wiser_heating_active",
    "wiser_cloud_connected",
    "measure_signal"
  ],
  "platforms": ["local"],
  "connectivity": ["lan"],
  "discovery": "wiser",
  "images": {
    "small": "/drivers/hub/assets/images/small.png",
    "large": "/drivers/hub/assets/images/large.png",
    "xlarge": "/drivers/hub/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "start"
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "id": "comfortMode",
      "type": "dropdown",
      "label": {
        "en": "Comfort Mode"
      },
      "value": "off",
      "values": [
        {
          "id": "off",
          "label": { "en": "Off" }
        },
        {
          "id": "on",
          "label": { "en": "On" }
        }
      ]
    },
    {
      "id": "ecoMode",
      "type": "dropdown",
      "label": {
        "en": "Eco Mode"
      },
      "value": "off",
      "values": [
        {
          "id": "off",
          "label": { "en": "Off" }
        },
        {
          "id": "on",
          "label": { "en": "On" }
        }
      ]
    },
    {
      "id": "pollInterval",
      "type": "number",
      "label": {
        "en": "Poll interval (seconds)"
      },
      "value": 30,
      "min": 5,
      "max": 3600
    },
    {
      "id": "useHttps",
      "type": "checkbox",
      "label": {
        "en": "Use HTTPS (self-signed)"
      },
      "value": false
    }
  ]
}
