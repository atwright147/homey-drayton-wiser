{
  "name": {
    "en": "Wiser Room"
  },
  "class": "thermostat",
  "capabilities": [
    "measure_temperature",
    "target_temperature",
    "measure_humidity",
    "wiser_room_mode"
  ],
  "capabilitiesOptions": {
    "target_temperature": {
      "min": 5,
      "max": 30,
      "step": 0.5
    }
  },
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "/drivers/room/assets/images/small.png",
    "large": "/drivers/room/assets/images/large.png",
    "xlarge": "/drivers/room/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ]
}
