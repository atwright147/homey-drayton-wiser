{
  "name": {
    "en": "Wiser Room"
  },
  "class": "thermostat",
  "capabilities": [
    "measure_temperature",
    "target_temperature",
    "measure_humidity",
    "wiser_room_mode"
  ],
  "capabilitiesOptions": {
    "target_temperature": {
      "min": 5,
      "max": 30,
      "step": 0.5
    }
  },
  "settings": [
    {
      "id": "roomMode",
      "type": "dropdown",
      "label": {
        "en": "Room Mode"
      },
      "value": "auto",
      "values": [
        {
          "id": "auto",
          "label": { "en": "Auto" }
        },
        {
          "id": "manual",
          "label": { "en": "Manual" }
        },
        {
          "id": "off",
          "label": { "en": "Off" }
        }
      ]
    }
  ],
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "/drivers/room/assets/images/small.png",
    "large": "/drivers/room/assets/images/large.png",
    "xlarge": "/drivers/room/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ]
}
