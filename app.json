{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.atwright.drayton-wiser",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "brandColor": "#E87722",
  "name": {
    "en": "Drayton Wiser"
  },
  "description": {
    "en": "Adds support for Drayton Wiser devices."
  },
  "category": [
    "climate"
  ],
  "permissions": [],
  "support": "mailto:atwright147@gmail.com",
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Andy Wright",
    "email": "atwright147@gmail.com"
  },
  "drivers": [
    {
      "name": {
        "en": "Wiser Hot Water"
      },
      "class": "other",
      "capabilities": [
        "wiser_hotwater_state",
        "wiser_hotwater_mode",
        "wiser_hotwater_next_event"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/hotwater/assets/images/small.png",
        "large": "/drivers/hotwater/assets/images/large.png",
        "xlarge": "/drivers/hotwater/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "hotwater"
    },
    {
      "name": {
        "en": "Wiser HeatHub"
      },
      "class": "other",
      "capabilities": [
        "wiser_away_mode",
        "wiser_heating_active",
        "wiser_cloud_connected",
        "measure_signal"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "wiser",
      "images": {
        "small": "/drivers/hub/assets/images/small.png",
        "large": "/drivers/hub/assets/images/large.png",
        "xlarge": "/drivers/hub/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "start"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "id": "pollInterval",
          "type": "number",
          "label": {
            "en": "Poll interval (seconds)"
          },
          "value": 30,
          "min": 5,
          "max": 3600
        },
        {
          "id": "useHttps",
          "type": "checkbox",
          "label": {
            "en": "Use HTTPS (self-signed)"
          },
          "value": false
        }
      ],
      "id": "hub"
    },
    {
      "name": {
        "en": "Wiser Room"
      },
      "class": "thermostat",
      "capabilities": [
        "measure_temperature",
        "target_temperature",
        "measure_humidity",
        "wiser_room_mode"
      ],
      "capabilitiesOptions": {
        "target_temperature": {
          "min": 5,
          "max": 30,
          "step": 0.5
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/room/assets/images/small.png",
        "large": "/drivers/room/assets/images/large.png",
        "xlarge": "/drivers/room/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "room"
    }
  ],
  "widgets": {
    "wiser-schedule": {
      "name": {
        "en": "Wiser Hot Water Schedule"
      },
      "height": 240,
      "devices": {
        "type": "app",
        "singular": true,
        "filter": {
          "capabilities": "wiser_hotwater_state"
        }
      },
      "api": {
        "getSchedule": {
          "method": "GET",
          "path": "/:deviceId"
        }
      },
      "id": "wiser-schedule",
      "settings": []
    }
  },
  "capabilities": {
    "measure_signal": {
      "type": "number",
      "title": {
        "en": "Signal Strength"
      },
      "getable": true,
      "setable": false,
      "units": {
        "en": "%"
      },
      "min": 0,
      "max": 100,
      "step": 1,
      "decimals": 0,
      "uiComponent": "sensor"
    },
    "wiser_away_mode": {
      "type": "boolean",
      "title": {
        "en": "Away Mode"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "toggle",
      "uiQuickAction": true,
      "insightsTitleTrue": {
        "en": "Away mode enabled"
      },
      "insightsTitleFalse": {
        "en": "Away mode disabled"
      }
    },
    "wiser_cloud_connected": {
      "type": "boolean",
      "title": {
        "en": "Cloud Connected"
      },
      "getable": true,
      "setable": false,
      "uiComponent": null,
      "insightsTitleTrue": {
        "en": "Cloud connection restored"
      },
      "insightsTitleFalse": {
        "en": "Cloud connection lost"
      }
    },
    "wiser_heating_active": {
      "type": "boolean",
      "title": {
        "en": "Heating Active"
      },
      "getable": true,
      "setable": false,
      "uiComponent": null,
      "insightsTitleTrue": {
        "en": "Heating turned on"
      },
      "insightsTitleFalse": {
        "en": "Heating turned off"
      }
    },
    "wiser_hotwater_mode": {
      "type": "enum",
      "title": {
        "en": "Hot Water Mode"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "values": [
        {
          "id": "auto",
          "title": {
            "en": "Auto"
          }
        },
        {
          "id": "on",
          "title": {
            "en": "On"
          }
        },
        {
          "id": "off",
          "title": {
            "en": "Off"
          }
        }
      ]
    },
    "wiser_hotwater_next_event": {
      "type": "string",
      "title": {
        "en": "Next Schedule Event"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/clock.svg"
    },
    "wiser_hotwater_state": {
      "type": "boolean",
      "title": {
        "en": "Heating"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/flame.svg",
      "insightsTitleTrue": {
        "en": "Hot water started heating"
      },
      "insightsTitleFalse": {
        "en": "Hot water stopped heating"
      }
    },
    "wiser_room_mode": {
      "type": "enum",
      "title": {
        "en": "Room Mode"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "values": [
        {
          "id": "auto",
          "title": {
            "en": "Auto"
          }
        },
        {
          "id": "manual",
          "title": {
            "en": "Manual"
          }
        },
        {
          "id": "off",
          "title": {
            "en": "Off"
          }
        }
      ]
    }
  },
  "discovery": {
    "wiser": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "http",
        "protocol": "tcp"
      },
      "id": "{{name}}",
      "conditions": [
        [
          {
            "field": "name",
            "match": {
              "type": "regex",
              "value": "WiserHeat.*"
            }
          }
        ]
      ]
    }
  }
}