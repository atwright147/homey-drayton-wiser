{
  "extends": "athom/homey-app",
  "settings": {
    "node": {
      "version": ">=22.0.0",
      "tryExtensions": [".js", ".ts", ".json", ".node"]
    },
    "import/resolver": {
      "node": { "extensions": [".js", ".ts", ".json", ".node"] }
    }
  },
  "parserOptions": {
    "project": "./tsconfig.lint.json"
  },
  "ignorePatterns": ["vitest.config.mts", ".homeybuild/", "node_modules/", "drivers/hub/pair/*.js"],
  "rules": {
    "import/extensions": ["error", "ignorePackages", {
      "js": "never", "jsx": "never", "ts": "never", "tsx": "never", "json": "always"
    }]
  },
  "overrides": [
    {
      "files": ["lib/wiser-client.ts", "lib/wiser-hub.ts"],
      "rules": { "homey-app/global-timers": "off" }
    },
    {
      "files": ["lib/wiser-errors.ts"],
      "rules": { "max-classes-per-file": "off" }
    },
    {
      "files": ["test/**/*.ts"],
      "rules": {
        "node/no-unpublished-import": "off",
        "node/no-unpublished-require": "off",
        "@typescript-eslint/no-misused-promises": "off"
      }
    }
  ]
}
